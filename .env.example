# ── ERP Switch — Variáveis de Ambiente ──────────────────────────────────────
# Copie para .env e preencha os valores

# JWT Secret — use uma string longa e aleatória em produção
# Gere com: openssl rand -base64 48
JWT_SECRET=troque-por-uma-chave-secreta-longa-e-aleatoria

# Domínio (usado nos scripts de deploy e nginx SSL)
DOMAIN=seudominio.com

# Email para Let's Encrypt (notificações de expiração)
CERTBOT_EMAIL=seu@email.com
